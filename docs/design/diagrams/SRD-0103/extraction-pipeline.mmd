%%{init: {'flowchart': {'nodeSpacing': 30, 'rankSpacing': 40}}}%%
flowchart TB
    subgraph Ex ["extraction"]
        direction TB
        I1["image ref"]
        Q1{{"tag?"}}
        H1["registry HEAD"]
        D1["digest"]
        CC1[("images table<br/>keyed by digest")]
        PULL["pull manifest<br/>parse @param<br/>infer ENV defaults<br/>build ParamSpace<br/>insert + cache"]
        PS1["ParamSpace<br/>(returned)"]
        I1 --> Q1
        Q1 -- tag --> H1 --> D1
        Q1 -- digest --> D1
        D1 --> CC1
        CC1 -- hit --> PS1
        CC1 -- miss --> PULL --> PS1
    end

    subgraph Val ["validation"]
        direction TB
        I2["bindings + image ref"]
        RES["apply defaults<br/>→ resolved binds"]
        DC["domain check<br/>pattern check<br/>valueSource verify"]
        RB["resolved binding<br/>(returned)"]
        I2 --> RES --> DC --> RB
    end

    classDef endpoint fill:#e8f0ff,stroke:#3366aa
    classDef store fill:#fff4e0,stroke:#aa7733
    classDef result fill:#e8ffe8,stroke:#338833
    class I1,I2 endpoint
    class CC1 store
    class PS1,RB result
