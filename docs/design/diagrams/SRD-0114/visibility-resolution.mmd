%%{init: {'flowchart': {'nodeSpacing': 40, 'rankSpacing': 60}}}%%
flowchart LR
    Start["resource<br/>request"]
    Q1{{"owner?"}}
    Q2{{"public?"}}
    Q3{{"explicit share?<br/>(principal,<br/>group, or<br/>active workspace)"}}
    Q4{{"admin role<br/>active?"}}

    A1["allowed"]
    A2["allowed<br/>(read only)"]
    A3["allowed<br/>(share permission)"]
    A4["allowed"]
    D["denied<br/>(silent or 404)"]

    Start --> Q1
    Q1 -- yes --> A1
    Q1 -- no --> Q2
    Q2 -- yes --> A2
    Q2 -- no --> Q3
    Q3 -- yes --> A3
    Q3 -- no --> Q4
    Q4 -- yes --> A4
    Q4 -- no --> D

    classDef ok fill:#e8ffe8,stroke:#338833
    classDef no fill:#ffe8e8,stroke:#aa3333
    class A1,A2,A3,A4 ok
    class D no
