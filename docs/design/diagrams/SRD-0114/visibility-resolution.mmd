flowchart TB
    Start["resource request"]
    Q1{{"principal is owner?"}}
    Q2{{"resource is public?"}}
    Q3{{"explicit resource_share<br/>(to principal, one of<br/>their groups, or their<br/>active workspace)?"}}
    Q4{{"admin role active?"}}

    Start --> Q1
    Q1 -- yes --> A1["allowed"]
    Q1 -- no --> Q2
    Q2 -- yes --> A2["allowed<br/>(read only,<br/>unless shared)"]
    Q2 -- no --> Q3
    Q3 -- yes --> A3["allowed<br/>(with share's permission)"]
    Q3 -- no --> Q4
    Q4 -- yes --> A4["allowed"]
    Q4 -- no --> D["denied<br/>(silent or 404,<br/>by context)"]

    classDef ok fill:#e8ffe8,stroke:#338833
    classDef no fill:#ffe8e8,stroke:#aa3333
    class A1,A2,A3,A4 ok
    class D no
