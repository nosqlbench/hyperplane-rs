%%{init: {'flowchart': {'nodeSpacing': 40, 'rankSpacing': 80}}}%%
flowchart LR
    PM["<b>Paramodel-owned</b><br/>(via SRD-0012 traits)<br/><br/>studies, plans, executions, elements<br/>parameters, checkpoints, journal_events<br/>trials, trial_metrics, artifacts"]
    BR["<b>Bridge tables</b><br/>(hyperplane-owned,<br/>FK into paramodel)<br/><br/>trial_deployments<br/>(trials.id ↔ container_id)<br/>execution_nodes<br/>(executions.id ↔ nodes.id)"]
    HP["<b>Hyperplane-owned</b><br/><br/>nodes, agents, deployments<br/>provisioning, images, image_tag_cache<br/>ssh_keys, config<br/>users, groups, roles, api_tokens<br/>workspaces, resource_shares<br/>audit_events, system_events"]

    PM -. "hyperplane reads<br/>via trait" .-> BR
    BR -. "FK" .-> HP

    Note["all three tiers live in<br/>ONE SQLite file per deployment<br/>(INV-STATE-SINGLE-FILE)"]
    HP -.-> Note

    classDef paramodel fill:#e8f0ff,stroke:#3366aa,stroke-width:2px
    classDef bridge fill:#fff4e0,stroke:#aa7733,stroke-width:2px
    classDef hyperplane fill:#e8ffe8,stroke:#338833,stroke-width:2px
    classDef note fill:#f0f0f0,stroke:#666
    class PM paramodel
    class BR bridge
    class HP hyperplane
    class Note note
