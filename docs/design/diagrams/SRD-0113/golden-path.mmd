flowchart TB
    subgraph P1 ["Phase 1 — authoring"]
        A1["hyper image register<br/>→ extract @param<br/>→ cache ParamSpace"]
        A2["write plan.yaml"]
        A3["hyper plan validate<br/>→ paramodel compile"]
        A4["hyper plan submit<br/>→ persist PlanSpec"]
        A1 --> A2 --> A3 --> A4
    end

    subgraph P2 ["Phase 2 — execution start"]
        B1["hyper execution start<br/>→ compile Atomic Step Graph<br/>→ EXECUTION_STARTED"]
    end

    subgraph P3 ["Phase 3 — provisioning"]
        C1["Deploy(host)<br/>EC2Node.materialize<br/>RunInstances<br/>state machine advances"]
        C2["Deploy(host-agent)<br/>SSH deploy once<br/>WebSocket opens<br/>Register<br/>REGISTERED → ACTIVE_HEARTBEAT"]
        C1 --> C2
    end

    subgraph P4 ["Phase 4 — workload"]
        D1["Deploy(harness)<br/>ServiceDocker<br/>EnsureContainerRunning<br/>docker pull + run<br/>healthcheck gate"]
        D2["Deploy(client)<br/>CommandDocker<br/>RunCommand<br/>docker run foreground"]
        D3["Await(client)<br/>block on exit<br/>agent captures payload"]
        D1 --> D2 --> D3
    end

    subgraph P5 ["Phase 5 — teardown"]
        E1["SaveOutput(client)<br/>TrialMetrics via ResultStore"]
        E2["Teardown(harness)<br/>EnsureContainerAbsent"]
        E3["Teardown(host)<br/>Shutdown → OS shutdown<br/>AWS terminates<br/>node: TERMINATED"]
        E1 --> E2 --> E3
    end

    subgraph P6 ["Phase 6 — query"]
        F1["hyper execution show /<br/>web UI /executions/{id}"]
        F2["query results + artifacts + events"]
        F1 --> F2
    end

    P1 --> P2 --> P3 --> P4 --> P5 --> P6

    classDef phase fill:#e8f0ff,stroke:#3366aa
    class A1,A2,A3,A4,B1,C1,C2,D1,D2,D3,E1,E2,E3,F1,F2 phase
