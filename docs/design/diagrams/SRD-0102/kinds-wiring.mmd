%%{init: {'flowchart': {'nodeSpacing': 50, 'rankSpacing': 80}}}%%
flowchart LR
    EC2["<b>EC2Node</b><br/>shutdown_semantics = Service<br/>socket: hosts"]
    AG["<b>Agent</b><br/>shutdown_semantics = Service<br/>plug: deploys-onto<br/>socket: commands-on"]
    SVC["<b>ServiceDocker</b><br/>shutdown_semantics = Service<br/>plug: commands-on<br/>socket: depends-on-service"]
    CMD["<b>CommandDocker</b><br/>shutdown_semantics = Command<br/>plug: commands-on<br/>plug: depends-on-service<br/>(optional)"]

    AG -- "Dedicated<br/>(deploys-onto ↔ hosts)" --> EC2
    SVC -- "Dedicated<br/>(commands-on ↔ commands-on)" --> AG
    CMD -- "Dedicated<br/>(commands-on ↔ commands-on)" --> AG
    CMD -. "Linear<br/>(optional)" .-> SVC

    classDef infra fill:#e8f0ff,stroke:#3366aa,stroke-width:2px
    classDef agent fill:#fff4e0,stroke:#aa7733
    classDef svc fill:#e8ffe8,stroke:#338833
    classDef cmd fill:#ffe8ff,stroke:#aa33aa
    class EC2 infra
    class AG agent
    class SVC svc
    class CMD cmd
