flowchart TB
    subgraph TCK ["paramodel-tck (opt-in)"]
        IP["ImplementationProvider family<br/>ParameterProvider, ElementProvider,<br/>TrialProvider, PlanProvider,<br/>ExecutorProvider, StorageProvider"]
        subgraph Cases ["Conformance cases"]
            Trait["trait-level cases<br/>(per trait: round-trip,<br/>errors, edge)"]
            Inv["invariant cases<br/>(every INV-* code<br/>has a case)"]
            Scen["scenario cases<br/>(end-to-end multi-trait)"]
        end
        Harn["Harness<br/>wires provider into cases<br/>produces pass/fail report"]
    end

    Mock["paramodel-mock (opt-in)<br/>in-memory reference impls<br/>baseline fixture for TCK + docs"]

    Adopter1["hyperplane-store-sqlite"]
    Adopter2["future backend"]

    IP --> Cases
    Cases --> Harn
    Mock -. "baseline" .-> Harn
    Adopter1 --> IP
    Adopter2 --> IP

    classDef tck fill:#e8f0ff,stroke:#3366aa
    classDef mock fill:#fff4e0,stroke:#aa7733
    classDef adopt fill:#e8ffe8,stroke:#338833
    class IP,Trait,Inv,Scen,Harn tck
    class Mock mock
    class Adopter1,Adopter2 adopt
