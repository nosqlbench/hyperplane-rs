flowchart TB
    User["User types: hyper execution show &lt;TAB&gt;"]
    Shell["shell<br/>(bash / zsh / fish / pwsh)"]
    Shim["shell completion hook<br/>(per-shell shim, installed once)"]
    Hyper["hyper __complete<br/>(same binary,<br/>internal subcommand)"]

    subgraph Dispatch ["veks-completion: parse partial command line → identify completion point → dispatch by source"]
        Static["static → compiled-in list"]
        File["file → filesystem"]
        Live["live → GET controller API"]
    end

    Live --> LC{{"success?"}}
    LC -- yes --> Refresh["refresh cache<br/>return live"]
    LC -- no --> Fall["fall back to cache<br/>(stale if older)"]

    Out["completions back to shell → rendered to user"]

    User --> Shell --> Shim --> Hyper --> Dispatch
    Static --> Out
    File --> Out
    Refresh --> Out
    Fall --> Out

    classDef user fill:#e8f0ff,stroke:#3366aa
    classDef bin fill:#fff4e0,stroke:#aa7733
    classDef dispatch fill:#e8ffe8,stroke:#338833
    class User,Shell user
    class Shim,Hyper bin
    class Static,File,Live,Refresh,Fall dispatch
